# keystore.properties.example
# Copia este archivo a keystore.properties y rellena los valores.
# ¡NUNCA comitas keystore.properties ni el archivo .jks al repositorio!
#
# Genera el keystore con:
#   keytool -genkey -v -keystore ~/upload-keystore.jks -keyalg RSA -keysize 2048 -validity 10000 -alias upload
#
# Para subirlo a GitHub Secrets como base64:
#   base64 -w 0 ~/upload-keystore.jks   # copia la salida como ANDROID_KEY_BASE64

password=TU_PASSWORD
keyAlias=upload
storeFile=/home/TU_USUARIO/upload-keystore.jks
